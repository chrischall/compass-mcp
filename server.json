{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.chrischall/compass-mcp",
  "description": "Compass real-estate for Claude — search, property details, photos, price history, compare",
  "repository": {
    "url": "https://github.com/chrischall/compass-mcp",
    "source": "github"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "compass-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "COMPASS_WS_PORT",
          "description": "Override the fetchproxy WebSocket port (default 37149).",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
